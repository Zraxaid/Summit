# --- Lead capture backend ---
# Required for /api/lead to persist submissions and send the recruiter
# notification email. Without these set, the endpoint still returns success
# to the visitor but only logs a warning server-side. Every submission is
# saved to Supabase regardless of email outcome, so no lead is ever lost.

# Supabase — server-side only. Grab the service_role secret from:
#   https://supabase.com/dashboard/project/auyeqzcprfnoyaquqklc/settings/api
SUPABASE_URL=https://auyeqzcprfnoyaquqklc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email. https://resend.com
RESEND_API_KEY=

# Notification recipient. NOTE: while the Resend account has no verified
# domain, it can ONLY deliver to the account owner's own address
# (protegionlife@gmail.com). To send to any other address (e.g.
# zraxaid@gmail.com), verify a domain at resend.com/domains and set
# LEAD_NOTIFICATION_FROM to an address on that domain.
LEAD_NOTIFICATION_EMAIL=protegionlife@gmail.com
LEAD_NOTIFICATION_FROM=Summit Leads <onboarding@resend.dev>
